# ============================================
# Teacher Timetable App - Environment Config
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- API Keys (for future integrations) ----
# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=
FCM_SENDER_ID=

# Sync / Cloud Backup (optional)
SYNC_ENABLED=false
SYNC_API_URL=
SYNC_API_KEY=

# ---- Notification Settings ----
# Web push notification VAPID keys (generate at https://web-push-codelab.glitch.me/)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:teacher@school.edu

# ---- Database (future PostgreSQL/MongoDB) ----
DB_TYPE=sqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=timetable
# DB_USER=postgres
# DB_PASSWORD=

# ---- Auth (future multi-teacher) ----
AUTH_ENABLED=false
JWT_SECRET=
SESSION_TIMEOUT=86400

# ---- School Defaults ----
DEFAULT_SCHOOL_START=08:00
DEFAULT_PERIOD_DURATION=40
DEFAULT_PERIODS_PER_DAY=12

# ---- Export ----
PDF_ENABLED=true
